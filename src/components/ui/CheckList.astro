---
interface Props {
  items: string[];
  class?: string;
}
const { items, class: extra = "" } = Astro.props;
---

<ul class={`space-y-3 ${extra}`}>
  {
    items.map((item) => (
      <li class="flex items-start gap-3">
        <span
          class="mt-0.5 grid size-5 shrink-0 place-items-center rounded-full bg-brand-soft text-brand-strong"
          aria-hidden="true"
        >
          <svg class="size-3" viewBox="0 0 20 20" fill="currentColor">
            <path
              fill-rule="evenodd"
              d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.3 3.3 6.8-6.8a1 1 0 0 1 1.4 0Z"
              clip-rule="evenodd"
            />
          </svg>
        </span>
        <span class="text-[0.97rem] leading-relaxed text-fg-muted">{item}</span>
      </li>
    ))
  }
</ul>
