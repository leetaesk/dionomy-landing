---
import CheckIcon from "./ui/CheckIcon.astro";
import Multiline from "./ui/Multiline.astro";
import {
  academyCategories,
  finalCtaHeading,
  finalCtaLead,
} from "../data/categories";
---

<section id="apply" class="section-y">
  <div class="container-content">
    <div
      class="relative overflow-hidden rounded-[2rem] bg-brand px-6 py-12 sm:px-10 sm:py-14 lg:px-14"
    >
      <!-- decorative glow -->
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div
          class="absolute -top-24 -left-20 size-72 rounded-full opacity-40 blur-3xl"
          style="background: radial-gradient(circle, rgba(255,255,255,0.6), transparent 70%);"
        >
        </div>
        <div
          class="absolute right-0 -bottom-28 size-80 rounded-full opacity-30 blur-3xl"
          style="background: radial-gradient(circle, rgba(32,29,74,0.7), transparent 70%);"
        >
        </div>
      </div>

      <div
        class="relative grid items-center gap-10 lg:grid-cols-[1fr_minmax(0,28rem)]"
      >
        <!-- copy -->
        <div class="reveal text-on-brand">
          <h2 class="text-h2 leading-[1.18] font-bold text-balance">
            <Multiline text={finalCtaHeading} />
          </h2>
          <p
            class="mt-5 max-w-md text-[1.02rem] leading-relaxed text-on-brand/85"
          >
            <Multiline text={finalCtaLead} />
          </p>
        </div>

        <!-- form card -->
        <div class="reveal" style="--reveal-delay: 100ms;">
          <div
            class="rounded-panel bg-bg p-6 shadow-[0_40px_80px_-30px_rgba(15,15,20,0.5)] sm:p-7"
          >
            <form id="apply-form" novalidate class="space-y-4">
              <div class="grid gap-4 sm:grid-cols-2">
                <div class="field">
                  <label for="f-name">이름</label>
                  <input
                    id="f-name"
                    name="name"
                    type="text"
                    autocomplete="name"
                    required
                    placeholder="홍길동"
                  />
                </div>
                <div class="field">
                  <label for="f-studio">스튜디오명</label>
                  <input
                    id="f-studio"
                    name="studio"
                    type="text"
                    required
                    placeholder="스튜디오 디오"
                  />
                </div>
              </div>

              <div class="field">
                <label for="f-phone">연락처</label>
                <input
                  id="f-phone"
                  name="phone"
                  type="tel"
                  inputmode="tel"
                  autocomplete="tel"
                  required
                  placeholder="010-0000-0000"
                />
              </div>

              <div class="field">
                <span class="field-label" id="f-category-label">
                  스튜디오 카테고리
                </span>
                <div class="combo" data-combo>
                  <button
                    type="button"
                    class="combo-btn is-placeholder"
                    aria-haspopup="listbox"
                    aria-expanded="false"
                    aria-labelledby="f-category-label"
                    data-combo-btn
                  >
                    <span data-combo-value>카테고리를 선택하세요</span>
                    <svg
                      class="combo-caret"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M5.3 7.3a1 1 0 0 1 1.4 0L10 10.58l3.3-3.3a1 1 0 0 1 1.4 1.42l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 0-1.42Z"
                        clip-rule="evenodd"></path>
                    </svg>
                  </button>
                  <ul
                    class="combo-list"
                    role="listbox"
                    aria-labelledby="f-category-label"
                    data-combo-list
                    hidden
                  >
                    {
                      academyCategories.map((c) => (
                        <li
                          class="combo-option"
                          role="option"
                          aria-selected="false"
                          tabindex="-1"
                          data-combo-option
                          data-value={c}
                        >
                          <span>{c}</span>
                          <svg
                            class="combo-check"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                            aria-hidden="true"
                          >
                            <path
                              fill-rule="evenodd"
                              d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.3 3.3 6.8-6.8a1 1 0 0 1 1.4 0Z"
                              clip-rule="evenodd"
                            />
                          </svg>
                        </li>
                      ))
                    }
                  </ul>
                  <input type="hidden" name="category" data-combo-input />
                </div>
                <p class="field-error" data-combo-error hidden>
                  카테고리를 선택해 주세요.
                </p>
              </div>

              <div class="field other-field" data-other-field hidden>
                <label for="f-category-other">어떤 스튜디오인가요?</label>
                <input
                  id="f-category-other"
                  name="categoryOther"
                  type="text"
                  placeholder="예: 클라이밍 · 요가 · 공방 등"
                  data-other-input
                />
              </div>

              <div class="consent-field">
                <label class="consent">
                  <input
                    id="f-consent"
                    name="consent"
                    type="checkbox"
                    required
                    data-consent
                  />
                  <span>
                    이름·연락처 등 개인정보의 <strong>수집·이용</strong>에
                    동의합니다. 수집한 정보는 얼리어답터 안내 목적에만 사용하며,
                    안내 완료 후 파기합니다.
                  </span>
                </label>
                <p class="field-error" data-consent-error hidden>
                  개인정보 수집·이용에 동의해 주세요.
                </p>
              </div>

              <button type="submit" class="submit-btn">무료로 신청하기</button>
              <p class="text-center text-[0.78rem] text-fg-faint">
                제출하시면 영업일 기준 1일 내에 연락드립니다.
              </p>
            </form>

            <!-- success state (hidden until submit) -->
            <div id="apply-success" hidden class="py-6 text-center">
              <div
                class="mx-auto grid size-14 place-items-center rounded-full bg-signal-ok-soft"
              >
                <CheckIcon class="size-7 text-signal-ok" />
              </div>
              <p class="mt-4 text-h3 font-bold text-fg">신청이 접수됐어요</p>
              <p class="mt-2 text-[0.92rem] text-fg-muted">
                영업일 기준 1일 내에 연락드리겠습니다. 감사합니다!
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- toast -->
  <div
    id="apply-toast"
    role="status"
    aria-live="polite"
    class="pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2 translate-y-4 rounded-pill bg-ink-950 px-5 py-3 text-sm font-semibold text-white opacity-0 shadow-lg transition-all duration-300"
  >
    신청이 접수됐어요 🎉
  </div>
</section>

<script>
  const form = document.getElementById("apply-form") as HTMLFormElement | null;
  const success = document.getElementById("apply-success");
  const toast = document.getElementById("apply-toast");

  // ── 중복 신청 방지: 이미 신청했으면 폼 대신 완료 화면 ──────────
  const APPLIED_KEY = "dionomy:applied";

  function showApplied() {
    if (form) form.hidden = true;
    if (success) success.hidden = false;
  }

  function hasApplied() {
    try {
      return localStorage.getItem(APPLIED_KEY) === "true";
    } catch {
      return false;
    }
  }

  function markApplied() {
    try {
      localStorage.setItem(APPLIED_KEY, "true");
    } catch {
      /* localStorage 사용 불가(시크릿 모드 등) 시 무시 */
    }
  }

  if (hasApplied()) showApplied();

  // ── custom category dropdown ──────────────────────────────
  const combo = document.querySelector<HTMLElement>("[data-combo]");
  const comboBtn = combo?.querySelector<HTMLButtonElement>("[data-combo-btn]");
  const comboList = combo?.querySelector<HTMLElement>("[data-combo-list]");
  const comboValue = combo?.querySelector<HTMLElement>("[data-combo-value]");
  const comboInput =
    combo?.querySelector<HTMLInputElement>("[data-combo-input]");
  const comboError = combo?.querySelector<HTMLElement>("[data-combo-error]");
  const comboOptions = Array.from(
    combo?.querySelectorAll<HTMLElement>("[data-combo-option]") ?? [],
  );
  const otherField = document.querySelector<HTMLElement>("[data-other-field]");
  const otherInput =
    document.querySelector<HTMLInputElement>("[data-other-input]");
  let activeIndex = -1;

  // 리스트를 body로 빼서(portal) 상위 박스의 overflow:hidden에 잘리지 않게 한다.
  if (comboList) document.body.appendChild(comboList);

  // 열릴 때마다 버튼 위치 기준으로 fixed 좌표를 계산한다(아래 공간 부족하면 위로).
  function positionCombo() {
    if (!comboBtn || !comboList) return;
    const r = comboBtn.getBoundingClientRect();
    comboList.style.left = `${r.left}px`;
    comboList.style.width = `${r.width}px`;
    const listH = comboList.offsetHeight;
    const spaceBelow = window.innerHeight - r.bottom;
    if (spaceBelow < listH + 8 && r.top > listH + 8) {
      comboList.style.top = `${r.top - listH - 6}px`;
    } else {
      comboList.style.top = `${r.bottom + 6}px`;
    }
  }

  function setActive(index: number) {
    activeIndex = index;
    comboOptions.forEach((opt, i) =>
      opt.classList.toggle("is-active", i === index),
    );
    if (index >= 0) comboOptions[index].focus();
  }

  function openCombo() {
    if (!comboList || !comboBtn) return;
    comboList.hidden = false;
    comboBtn.setAttribute("aria-expanded", "true");
    positionCombo();
    const selected = comboOptions.findIndex(
      (o) => o.getAttribute("aria-selected") === "true",
    );
    setActive(selected >= 0 ? selected : 0);
  }

  function closeCombo(focusBtn = true) {
    if (!comboList || !comboBtn) return;
    comboList.hidden = true;
    comboBtn.setAttribute("aria-expanded", "false");
    activeIndex = -1;
    comboOptions.forEach((opt) => opt.classList.remove("is-active"));
    if (focusBtn) comboBtn.focus();
  }

  function selectOption(opt: HTMLElement) {
    if (!comboInput || !comboValue || !comboBtn) return;
    const value = opt.dataset.value ?? "";
    comboInput.value = value;
    comboValue.textContent = value;
    comboBtn.classList.remove("is-placeholder", "has-error");
    comboOptions.forEach((o) =>
      o.setAttribute("aria-selected", o === opt ? "true" : "false"),
    );
    comboError?.setAttribute("hidden", "");

    // "기타" 선택 시 직접 입력 필드 노출
    if (otherField && otherInput) {
      const isOther = value === "기타";
      otherField.hidden = !isOther;
      otherInput.required = isOther;
      if (!isOther) otherInput.value = "";
    }

    closeCombo();
    if (otherInput && value === "기타") otherInput.focus();
  }

  comboBtn?.addEventListener("click", () => {
    if (comboList?.hidden) openCombo();
    else closeCombo();
  });

  comboBtn?.addEventListener("keydown", (e) => {
    if (e.key === "ArrowDown" || e.key === "Enter" || e.key === " ") {
      e.preventDefault();
      openCombo();
    }
  });

  comboOptions.forEach((opt, i) => {
    opt.addEventListener("click", () => selectOption(opt));
    opt.addEventListener("mouseenter", () => setActive(i));
    opt.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        setActive((activeIndex + 1) % comboOptions.length);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        setActive(
          (activeIndex - 1 + comboOptions.length) % comboOptions.length,
        );
      } else if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        selectOption(opt);
      } else if (e.key === "Escape") {
        e.preventDefault();
        closeCombo();
      } else if (e.key === "Tab") {
        closeCombo(false);
      }
    });
  });

  document.addEventListener("click", (e) => {
    const t = e.target as Node;
    if (combo && !combo.contains(t) && !comboList?.contains(t)) {
      closeCombo(false);
    }
  });

  // 스크롤·리사이즈 시 열려 있으면 위치 재계산(fixed라 따라가야 함)
  window.addEventListener(
    "scroll",
    () => {
      if (comboList && !comboList.hidden) positionCombo();
    },
    true,
  );
  window.addEventListener("resize", () => {
    if (comboList && !comboList.hidden) positionCombo();
  });

  // ── form submit ───────────────────────────────────────────
  const FORM_ENDPOINT = import.meta.env.PUBLIC_FORM_ENDPOINT;

  const phoneInput = document.getElementById(
    "f-phone",
  ) as HTMLInputElement | null;
  const consentInput =
    document.querySelector<HTMLInputElement>("[data-consent]");
  const consentError = document.querySelector<HTMLElement>(
    "[data-consent-error]",
  );
  const consentField = consentInput?.closest<HTMLElement>(".consent-field");
  const submitBtn = form?.querySelector<HTMLButtonElement>(".submit-btn");

  // 연락처 검증: 숫자만 추출해 휴대폰 형식 확인 (010-0000-0000 등)
  function isValidPhone(v: string) {
    return /^01[016789]\d{7,8}$/.test(v.replace(/\D/g, ""));
  }

  // GA 전환 이벤트 — gtag 미로드 시 안전하게 무시
  function track(name: string, params: Record<string, unknown> = {}) {
    (window as unknown as { gtag?: (...a: unknown[]) => void }).gtag?.(
      "event",
      name,
      params,
    );
  }

  function showToast(message: string) {
    if (!toast) return;
    toast.textContent = message;
    toast.classList.remove("opacity-0", "translate-y-4");
    toast.classList.add("opacity-100", "translate-y-0");
    window.setTimeout(() => {
      toast.classList.add("opacity-0", "translate-y-4");
      toast.classList.remove("opacity-100", "translate-y-0");
    }, 3200);
  }

  // 첫 입력 시 퍼널 이벤트 1회
  let formStarted = false;
  form?.addEventListener("input", () => {
    if (formStarted) return;
    formStarted = true;
    track("apply_form_start");
  });

  function onSuccess() {
    track("generate_lead", { method: "early_adopter" });
    markApplied();
    if (form) form.hidden = true;
    if (success) success.hidden = false;
    showToast("신청이 접수됐어요 🎉");
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const categoryValid = !!comboInput?.value;
    if (!categoryValid) {
      comboError?.removeAttribute("hidden");
      comboBtn?.classList.add("has-error");
    }

    // 연락처 형식 검증(네이티브 검증 메시지로 노출)
    if (phoneInput) {
      phoneInput.setCustomValidity(
        isValidPhone(phoneInput.value)
          ? ""
          : "올바른 연락처를 입력해 주세요. 예: 010-0000-0000",
      );
    }

    // 동의 검증
    const consentValid = !!consentInput?.checked;
    consentError?.toggleAttribute("hidden", consentValid);
    consentField?.classList.toggle("has-error", !consentValid);

    const nativeValid = form.checkValidity();
    if (!nativeValid) form.reportValidity();
    if (!nativeValid || !categoryValid || !consentValid) return;

    const data = Object.fromEntries(new FormData(form).entries());

    // 백엔드 미설정(로컬 개발 등) → 콘솔 스텁으로 성공 처리
    if (!FORM_ENDPOINT) {
      console.warn(
        "[dionomy] PUBLIC_FORM_ENDPOINT 미설정 — 제출 데이터:",
        data,
      );
      onSuccess();
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "신청 중…";
    }

    try {
      const res = await fetch(FORM_ENDPOINT, {
        method: "POST",
        // text/plain → CORS preflight 회피(simple request), 정상 응답 수신
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error(`status ${res.status}`);
      onSuccess();
    } catch (err) {
      console.error("[dionomy] 신청 전송 실패:", err);
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "무료로 신청하기";
      }
      showToast("전송에 실패했어요. 잠시 후 다시 시도해 주세요.");
    }
  });
</script>

<style>
  .field label,
  .field-label {
    display: block;
    margin-bottom: 0.4rem;
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--color-fg-muted);
  }
  .field input {
    width: 100%;
    border-radius: 0.7rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    padding: 0.7rem 0.85rem;
    font-size: 0.95rem;
    color: var(--color-fg);
    transition:
      border-color 0.18s,
      box-shadow 0.18s;
    appearance: none;
  }
  .field input::placeholder {
    color: var(--color-fg-faint);
  }
  .field input:focus {
    outline: none;
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px
      color-mix(in srgb, var(--color-brand) 18%, transparent);
  }

  /* custom dropdown */
  .combo {
    position: relative;
  }
  .combo-btn {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    border-radius: 0.7rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    padding: 0.7rem 0.85rem;
    font-size: 0.95rem;
    color: var(--color-fg);
    text-align: left;
    cursor: pointer;
    transition:
      border-color 0.18s,
      box-shadow 0.18s;
  }
  .combo-btn:hover {
    border-color: var(--color-border-strong);
  }
  .combo-btn:focus-visible,
  .combo-btn[aria-expanded="true"] {
    outline: none;
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px
      color-mix(in srgb, var(--color-brand) 18%, transparent);
  }
  .combo-btn.is-placeholder {
    color: var(--color-fg-faint);
  }
  .combo-btn.has-error {
    border-color: var(--color-signal-risk);
    box-shadow: 0 0 0 3px
      color-mix(in srgb, var(--color-signal-risk) 16%, transparent);
  }
  .combo-caret {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    color: var(--color-fg-subtle);
    transition: transform 0.18s ease;
  }
  .combo-btn[aria-expanded="true"] .combo-caret {
    transform: rotate(180deg);
  }
  .combo-list {
    position: fixed;
    z-index: 1000;
    max-height: 15rem;
    overflow-y: auto;
    margin: 0;
    padding: 0.35rem;
    list-style: none;
    border-radius: 0.85rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    box-shadow: 0 22px 44px -22px rgba(15, 15, 20, 0.4);
  }
  .combo-list[hidden] {
    display: none;
  }
  .combo-list:not([hidden]) {
    animation: combo-in 0.14s ease;
  }
  @keyframes combo-in {
    from {
      opacity: 0;
      transform: translateY(-0.35rem);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .combo-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.6rem 0.7rem;
    border-radius: 0.55rem;
    font-size: 0.93rem;
    color: var(--color-fg);
    cursor: pointer;
    outline: none;
  }
  .combo-option.is-active {
    background: var(--color-bg-subtle);
  }
  .combo-option[aria-selected="true"] {
    color: var(--color-brand-strong);
    font-weight: 600;
  }
  .combo-check {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--color-brand);
    opacity: 0;
  }
  .combo-option[aria-selected="true"] .combo-check {
    opacity: 1;
  }
  .field-error {
    margin-top: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-signal-risk);
  }
  .other-field[hidden] {
    display: none;
  }
  .other-field:not([hidden]) {
    animation: combo-in 0.16s ease;
  }

  /* consent checkbox */
  .consent {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    cursor: pointer;
  }
  .consent input {
    margin-top: 0.15rem;
    width: 1.05rem;
    height: 1.05rem;
    flex-shrink: 0;
    accent-color: var(--color-brand);
    cursor: pointer;
  }
  .consent span {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-fg-muted);
  }
  .consent strong {
    color: var(--color-fg);
    font-weight: 600;
  }
  .consent-field.has-error .consent input {
    outline: 2px solid var(--color-signal-risk);
    outline-offset: 2px;
    border-radius: 0.2rem;
  }

  .submit-btn {
    width: 100%;
    border-radius: var(--radius-pill);
    background: var(--color-brand);
    padding: 0.85rem 1rem;
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-on-brand);
    transition:
      background-color 0.18s,
      transform 0.18s;
  }
  .submit-btn:hover {
    background: var(--color-brand-strong);
    transform: translateY(-1px);
  }
  .submit-btn:active {
