---
import CheckList from "./ui/CheckList.astro";
import { solutions } from "../data/solutions";
import {
  careCards,
  riskLabel,
  careTrustBadge,
  careTrustBody,
  type RiskLevel,
} from "../data/care";

const s = solutions.find((x) => x.id === "ai-crm")!;
const titleLines = s.title.split("\n");

const riskStyle: Record<RiskLevel, string> = {
  high: "bg-signal-risk-soft text-rose-700",
  medium: "bg-signal-warn-soft text-amber-700",
  watch: "bg-bg-muted text-fg-muted",
};
const riskDot: Record<RiskLevel, string> = {
  high: "bg-signal-risk",
  medium: "bg-signal-warn",
  watch: "bg-fg-faint",
};
---

<div class="container-content grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
  <!-- copy -->
  <div class="reveal lg:sticky lg:top-28">
    <div class="flex items-center gap-3">
      <span
        class="grid size-9 place-items-center rounded-xl bg-brand text-sm font-bold text-on-brand"
        >{s.number}</span
      >
      <span class="text-sm font-semibold text-brand-strong">{s.eyebrow}</span>
    </div>
    <h3 class="mt-5 text-h2 text-fg">
      {
        titleLines.map((line, i) => (
          <>
            {line}
            {i < titleLines.length - 1 && <br />}
          </>
        ))
      }
    </h3>
    <p class="mt-5 text-lead text-fg-muted">{s.lead}</p>
    <CheckList items={s.points} class="mt-7" />

    <!-- trust badge -->
    <div
      class="mt-8 rounded-2xl border border-brand-softer bg-brand-soft/60 p-5"
    >
      <div class="flex items-center gap-2.5">
        <span
          class="grid size-7 place-items-center rounded-full bg-brand text-on-brand"
        >
          <svg class="size-4" viewBox="0 0 20 20" fill="currentColor">
            <path
              fill-rule="evenodd"
              d="M10 1.5 3 4.3v4.4c0 4 2.8 7.7 7 9.3 4.2-1.6 7-5.3 7-9.3V4.3L10 1.5Zm3.2 6.3-3.8 4a.8.8 0 0 1-1.16.02L6.8 10.2a.8.8 0 1 1 1.14-1.12l.86.88 3.24-3.4a.8.8 0 1 1 1.16 1.1Z"
              clip-rule="evenodd"></path>
          </svg>
        </span>
        <p class="text-[0.95rem] font-bold text-fg">{careTrustBadge}</p>
      </div>
      <p class="mt-2.5 text-[0.9rem] leading-relaxed text-fg-muted">
        {careTrustBody}
      </p>
    </div>
  </div>

  <!-- backoffice care panel -->
  <div class="reveal" style="--reveal-delay: 100ms;">
    <div
      class="overflow-hidden rounded-panel border border-border bg-bg shadow-[0_30px_60px_-36px_rgba(32,29,74,0.4)]"
    >
      <!-- window chrome -->
      <div
        class="flex items-center gap-2 border-b border-border bg-bg-subtle px-4 py-3"
      >
        <span class="flex gap-1.5" aria-hidden="true">
          <span class="size-2.5 rounded-full bg-border-strong"></span>
          <span class="size-2.5 rounded-full bg-border-strong"></span>
          <span class="size-2.5 rounded-full bg-border-strong"></span>
        </span>
        <p class="ml-2 text-[0.8rem] font-semibold text-fg-muted">
          Dionomy 백오피스 · 케어 보드
        </p>
      </div>

      <div class="p-4 sm:p-5">
        <div class="flex items-center justify-between">
          <p class="text-h3 font-bold text-fg">이번 주에 챙겨야 할 수강생</p>
          <span
            class="rounded-pill bg-brand-soft px-2.5 py-1 text-[0.7rem] font-semibold text-brand-strong"
            >{careCards.length}명</span
          >
        </div>

        <ul class="mt-4 space-y-3">
          {
            careCards.map((c) => (
              <li class="rounded-2xl border border-border bg-bg p-4 transition-shadow hover:shadow-[0_18px_36px_-24px_rgba(32,29,74,0.4)]">
                <div class="flex items-center justify-between gap-3">
                  <div class="flex items-center gap-3">
                    <span class="grid size-9 place-items-center rounded-full bg-bg-muted text-sm font-bold text-fg-muted">
                      {c.name.charAt(0)}
                    </span>
                    <div class="leading-tight">
                      <p class="text-[0.95rem] font-bold text-fg">{c.name}</p>
                      <p class="text-[0.75rem] text-fg-subtle">{c.meta}</p>
                    </div>
                  </div>
                  <span
                    class:list={[
                      "inline-flex items-center gap-1.5 rounded-pill px-2.5 py-1 text-[0.7rem] font-bold",
                      riskStyle[c.level],
                    ]}
                  >
                    <span
                      class:list={["size-1.5 rounded-full", riskDot[c.level]]}
                      aria-hidden="true"
                    />
                    {riskLabel[c.level]}
                  </span>
                </div>

                <div class="mt-3.5 space-y-2.5 border-t border-border pt-3.5">
                  <div class="flex gap-2.5">
                    <span class="mt-px text-[0.66rem] font-bold text-fg-faint">
                      신호
                    </span>
                    <p class="text-[0.83rem] leading-relaxed text-fg-muted">
                      {c.signal}
                    </p>
                  </div>
                  <div class="flex gap-2.5">
                    <span class="mt-px text-[0.66rem] font-bold text-brand">
                      제안
                    </span>
                    <p class="text-[0.83rem] leading-relaxed text-fg">
                      {c.action}
                    </p>
                  </div>
                </div>

                <div class="mt-3.5 flex gap-2">
                  <button
                    type="button"
                    class="flex-1 rounded-lg bg-brand py-2 text-[0.78rem] font-semibold text-on-brand transition-colors hover:bg-brand-strong"
                    tabindex="-1"
                  >
                    상담 초안 보기
                  </button>
                  <button
                    type="button"
                    class="rounded-lg bg-bg-subtle px-3 py-2 text-[0.78rem] font-semibold text-fg-muted transition-colors hover:bg-bg-muted"
                    tabindex="-1"
                  >
                    나중에
                  </button>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</div>
