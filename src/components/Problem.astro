---
import Eyebrow from "./ui/Eyebrow.astro";
import {
  problemEyebrow,
  problemHeading,
  problemLead,
  problemSteps,
  problemClosing,
} from "../data/problem";

const headingLines = problemHeading.split("\n");
---

<section id="problem" class="section-y bg-bg-subtle">
  <div class="container-content">
    <div class="reveal mx-auto max-w-2xl text-center">
      <Eyebrow>{problemEyebrow}</Eyebrow>
      <h2 class="mt-5 text-h2 text-fg">
        {
          headingLines.map((line, i) => (
            <>
              {line}
              {i < headingLines.length - 1 && <br />}
            </>
          ))
        }
      </h2>
      <p class="mt-5 text-lead text-fg-muted">{problemLead}</p>
    </div>

    <ol class="mt-14 grid gap-5 md:grid-cols-3 md:gap-6">
      {
        problemSteps.map((step, i) => (
          <li
            class="reveal group relative flex flex-col rounded-panel border border-border bg-bg p-7 transition-shadow duration-300 hover:shadow-[0_24px_48px_-28px_rgba(32,29,74,0.35)]"
            style={`--reveal-delay: ${i * 90}ms;`}
          >
            <span class="text-sm font-bold text-fg-faint">{step.index}</span>
            <h3 class="mt-3 text-h3 text-fg">{step.title}</h3>
            <p class="mt-3 text-[0.97rem] leading-relaxed text-fg-muted">
              {step.body}
            </p>
            {i < problemSteps.length - 1 && (
              <span
                class="absolute top-1/2 -right-3 z-10 hidden size-6 -translate-y-1/2 place-items-center rounded-full border border-border bg-bg text-fg-faint md:grid"
                aria-hidden="true"
              >
                <svg class="size-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    fill-rule="evenodd"
                    d="M7.3 4.3a1 1 0 0 1 1.4 0l5 5a1 1 0 0 1 0 1.4l-5 5a1 1 0 1 1-1.4-1.4L11.58 10 7.3 5.7a1 1 0 0 1 0-1.4Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </span>
            )}
          </li>
        ))
      }
    </ol>

    <p
      class="reveal mx-auto mt-14 max-w-2xl text-center text-h3 font-semibold text-balance text-fg"
    >
      {problemClosing}
    </p>
  </div>
</section>
