---
import SectionHeader from "./ui/SectionHeader.astro";
import Button from "./ui/Button.astro";
import CheckIcon from "./ui/CheckIcon.astro";
import { pricingHeading, pricingLead, partnerBanner } from "../data/pricing";
import { primaryCta } from "../data/navigation";
---

<section id="pricing" class="section-y bg-bg-subtle">
  <div class="container-content">
    <SectionHeader eyebrow="요금" heading={pricingHeading} lead={pricingLead} />

    <!-- 첫 파트너 모집 배너 -->
    <div
      class="reveal relative mx-auto mt-14 max-w-4xl overflow-hidden rounded-panel p-8 ring-1 ring-white/10 sm:p-10"
      style="background: linear-gradient(135deg, var(--color-primary-700) 0%, var(--color-primary-900) 55%, var(--color-primary-950) 100%);"
    >
      <!-- 우상단 브랜드 글로우 -->
      <div
        class="pointer-events-none absolute -top-20 -right-16 size-64 rounded-full opacity-60 blur-3xl"
        style="background: radial-gradient(circle, rgba(149,149,227,0.65), transparent 70%);"
        aria-hidden="true"
      >
      </div>
      <!-- 좌하단 깊이감 글로우 -->
      <div
        class="pointer-events-none absolute -bottom-24 -left-20 size-72 rounded-full opacity-40 blur-3xl"
        style="background: radial-gradient(circle, rgba(91,91,214,0.6), transparent 72%);"
        aria-hidden="true"
      >
      </div>
      <div class="relative">
        <span
          class="inline-flex items-center gap-2 rounded-pill bg-white/10 px-3 py-1 text-[0.78rem] font-semibold text-white/90"
        >
          <span class="size-1.5 rounded-full bg-signal-warn"></span>
          {partnerBanner.eyebrow}
        </span>
        <h3 class="mt-4 text-h3 font-bold text-white sm:text-2xl">
          {partnerBanner.title}
        </h3>
        <p
          class="mt-3 max-w-xl text-[0.95rem] leading-relaxed whitespace-pre-line text-white/70"
        >
          {partnerBanner.body}
        </p>

        <ul class="mt-7 grid gap-3 sm:grid-cols-2">
          {
            partnerBanner.features.map((feature) => (
              <li class="flex items-start gap-3">
                <span
                  class="mt-0.5 grid size-5 shrink-0 place-items-center rounded-full bg-white/15 text-white"
                  aria-hidden="true"
                >
                  <CheckIcon class="size-3" />
                </span>
                <span class="text-[0.95rem] leading-relaxed text-white/85">
                  {feature}
                </span>
              </li>
            ))
          }
        </ul>

        <div class="mt-10 flex justify-center">
          <div class="cta-float">
            <Button href={primaryCta.href} variant="primary" size="lg">
              {primaryCta.label}
              <svg
                class="size-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M12 5v14" />
                <path d="m19 12-7 7-7-7" />
              </svg>
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes ctaFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }
  .cta-float {
    animation: ctaFloat 2.4s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .cta-float {
      animation: none;
    }
  }
</style>
